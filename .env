PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# Redis — opcional. Si no tienes Redis instalado, se usa cache en memoria automáticamente
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth — para uso local puedes dejar la misma key en todas las peticiones
# o setear DISABLE_AUTH=true en auth.middleware si quieres sin auth
API_KEY=lino-tv-dev-key
JWT_SECRET=lino-tv-jwt-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# TTL Cache (segundos)
CACHE_TTL_HOME=3600
CACHE_TTL_SEARCH=1800
CACHE_TTL_DETAIL=7200
CACHE_TTL_EPISODES=1800
CACHE_TTL_STREAM=300

# Features
ENABLE_CACHE=true
ENABLE_RATE_LIMIT=false
ENABLE_SWAGGER=true

# Dominios de proveedores (actualizar si cambian de dominio)
ANIMEFLV_DOMAIN=https://www3.animeflv.net
ANIMEAV1_DOMAIN=https://animeav1.com
JKANIME_DOMAIN=https://jkanime.net
MONOSCHINOS_DOMAIN=https://monoschinos.com
TIOANIME_DOMAIN=https://tioanime.com
PELISPLUS_DOMAIN=https://www.pelisplushd.la
CUEVANA_DOMAIN=https://cuevana3.me
REPELISHD_DOMAIN=https://repelishd.com

# Logging
LOG_LEVEL=info
LOG_FILE=logs/lino-tv.log

USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
